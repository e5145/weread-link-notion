# Required
WEREAD_API_KEY=wrk_xxxxxxxxxxxxxxxxx
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxx
NOTION_PAGE=https://www.notion.so/your-page-id

# GitHub Actions fills these automatically. For local tests you may set them manually.
GITHUB_REPOSITORY=your-name/weread-link-notion
GITHUB_BRANCH=main

# Optional
SYNC_NOTES=true
MAX_NOTEBOOKS=0
WEREAD_SKILL_VERSION=1.0.3
WEREAD_API_TIMEOUT=30
HEATMAP_PATH=assets/heatmap.png
